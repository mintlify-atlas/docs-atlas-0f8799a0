  "keyFeatures": [
    "Batch image compression with quality control (JPEG, PNG, WEBP, AVIF, HEIC, and more)",
    "Format conversion between all major image formats",
    "AI-powered background removal using rembg (offline-capable)",
    "Automatic color palette extraction with HEX, RGB, and HSL export",
    "EXIF metadata viewing, editing, and bulk cleanup",
    "Batch file renaming with live preview",
    "LQIP (Low Quality Image Placeholder) and Base64 generation for web workflows",
    "Image resizing, rotation, flip, and canvas editing",
    "Watermark application with real-time preview",
    "OCR text extraction using EasyOCR",
    "SVG vectorization from raster images",
    "Multi-language support (Spanish, English, Portuguese) with dark themes"
  ],
